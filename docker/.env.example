# ============================================================================
# 모니터링 스택 환경 변수 예시
# ============================================================================
# 사용법: 이 파일을 .env로 복사한 뒤 값을 채우세요.
#   cp .env.example .env
# docker compose가 같은 디렉토리의 .env를 자동으로 읽어 적용합니다.
# .env는 .gitignore에 포함되어 커밋되지 않습니다.
# ============================================================================

# ----------------------------------------------------------------------------
# Grafana 관리자 계정 (프로덕션에서는 반드시 변경)
# ----------------------------------------------------------------------------
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# ----------------------------------------------------------------------------
# 이미지 버전 고정 (업그레이드 시 이 값만 변경)
# ----------------------------------------------------------------------------
PROMETHEUS_VERSION=v3.1.0
GRAFANA_VERSION=11.4.0
LOKI_VERSION=3.3.2
ALLOY_VERSION=v1.5.1
